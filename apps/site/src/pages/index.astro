---
import { readFileSync, existsSync } from "node:fs";
import { resolve, dirname } from "node:path";
import { siteConfig } from "../../site.config.mjs";
import Analytics from "@vercel/analytics/astro";
import "../styles/custom.css";

function findCliPackageJson(): string | null {
  let dir = process.cwd();
  for (let i = 0; i < 10; i++) {
    const p = resolve(dir, "packages", "tui-bridge", "package.json");
    if (existsSync(p)) return p;
    const parent = dirname(dir);
    if (parent === dir) break;
    dir = parent;
  }
  return null;
}

let version: string | null = null;
const cliPkgPath = findCliPackageJson();
if (cliPkgPath) {
  try {
    version = JSON.parse(readFileSync(cliPkgPath, "utf8")).version ?? null;
  } catch {}
}
const year = new Date().getFullYear();
const site = siteConfig.url;
const ogImage = `${site}/og.png`;

const installTabs = [
  {
    id: "macos-linux",
    label: "macOS / Linux",
    command: `curl -fsSL ${site}/install | bash`,
    hint: "then:",
  },
  {
    id: "windows",
    label: "Windows",
    command: `irm ${site}/install.ps1 | iex`,
    hint: "then:",
  },
  {
    id: "npm",
    label: "npm",
    command: "npm i -g tui-bridge@latest",
    hint: "then:",
  },
];

const screenshotsDir = resolve(process.cwd(), "public", "screenshots");
const hasPhoneDemo = existsSync(resolve(screenshotsDir, "phone-demo.png"));
const hasQrPairing = existsSync(resolve(screenshotsDir, "qr-pairing.png"));
const hasAnyScreenshot = hasPhoneDemo || hasQrPairing;

const navLinks = [
  { label: "Docs", href: "/getting-started/" },
  { label: "GitHub", href: siteConfig.repo.url },
  { label: "npm", href: siteConfig.npm.url },
];

const features = [
  {
    title: "Any TUI, anywhere",
    body: "opencode, htop, lazygit, vim — if it runs in a terminal, it runs on your phone.",
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m4 17 6-6-6-6"/><path d="M12 19h8"/></svg>',
  },
  {
    title: "Pairing-token auth",
    body: "A one-time token delivered via QR code. The public URL is not the secret.",
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>',
  },
  {
    title: "Ephemeral tunnel",
    body: "A Cloudflare Quick Tunnel gives you an HTTPS URL with no port forwarding.",
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>',
  },
  {
    title: "Mobile-first controls",
    body: "Ctrl, Alt, Esc, Tab, arrows and page keys as big tappable buttons.",
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>',
  },
  {
    title: "Survives reconnects",
    body: "An xterm headless mirror sends a snapshot to every reconnecting client.",
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h.01"/><path d="M2 8.82a15 15 0 0 1 20 0"/><path d="M5 12.859a10 10 0 0 1 14 0"/><path d="M8.5 16.429a5 5 0 0 1 7 0"/></svg>',
  },
  {
    title: "Open source",
    body: "MIT licensed. No central server, no account, no telemetry.",
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>',
  },
];

const flowSteps = [
  {
    title: "Run",
    body: "tui-bridge spawns your TUI inside a local PTY and opens an anonymous Cloudflare Quick Tunnel for an HTTPS URL.",
  },
  {
    title: "Pair",
    body: "Scan the QR shown in your terminal. A one-time token in the URL fragment authenticates your phone — it never reaches the server.",
  },
  {
    title: "Drive",
    body: "The mobile xterm.js mirrors the desktop terminal grid. Type, scroll, and tap the toolbar keys from anywhere.",
  },
];

const compareRows = [
  { label: "NAT / firewall traversal", tb: ["yes", "Quick Tunnel"], ssh: ["no", "needs VPN"], ngrok: ["yes", "ngrok tunnel"] },
  { label: "Auth model", tb: ["yes", "QR pairing token"], ssh: ["no", "SSH keys"], ngrok: ["no", "URL only"] },
  { label: "Mobile keys (Ctrl/Alt/Tab/arrows)", tb: ["yes", "toolbar"], ssh: ["no", "—"], ngrok: ["no", "varies"] },
  { label: "Account required", tb: ["yes", "none"], ssh: ["yes", "none"], ngrok: ["no", "ngrok account"] },
  { label: "Reconnect snapshot", tb: ["yes", "headless mirror"], ssh: ["no", "session lost"], ngrok: ["no", "—"] },
  { label: "Setup time", tb: ["yes", "~60s"], ssh: ["no", "long"], ngrok: ["no", "medium"] },
];

const usecases = [
  {
    title: "Couch coding",
    body: "Step away without losing your session. Keep an editor or REPL open on the desktop and drive it from the sofa.",
  },
  {
    title: "Long builds on the move",
    body: "Kick off a test suite or migration, then leave. Reconnect from your phone to inspect output the moment it finishes.",
  },
  {
    title: "Headless monitoring",
    body: "Run htop, lazydocker, or a log tailer on a box with no display. Check in from anywhere by scanning a QR.",
  },
];

const faq = [
  {
    q: "Which TUIs work?",
    a: "Anything that runs in a terminal: opencode, htop, lazygit, vim, btop, mc and more. If it speaks to a PTY, tui-bridge can mirror it.",
  },
  {
    q: "Is it secure?",
    a: "The public URL is not the secret. A one-time QR carries a pairing token in the URL fragment — never sent to the server or Cloudflare. It is single-use with a 5-minute expiry, and session credentials are hashed and compared in constant time.",
  },
  {
    q: "Do I need a Cloudflare account?",
    a: "No. Quick Tunnels are anonymous and ephemeral. With --lan (same WiFi) you need nothing external at all; cloudflared is only required for the public tunnel.",
  },
  {
    q: "Does it work on Windows?",
    a: "Yes. Windows with ConPTY is the primary platform. Linux is supported; macOS is a fast-follower and currently untested.",
  },
  {
    q: "Can multiple phones connect?",
    a: "Yes. Any authenticated client can type — there is no input lock. The desktop terminal grid is mirrored to every connected client.",
  },
  {
    q: "Does the phone resize the terminal?",
    a: "No. The desktop is the sole authority on PTY size. The phone mirrors the grid and scrolls horizontally, so coordinate-based TUIs never break.",
  },
  {
    q: "Is there a daemon or central server?",
    a: "No. One PTY per process, no background daemon, no account, and no telemetry. MIT licensed and fully open source.",
  },
  {
    q: "What if the connection drops?",
    a: "A headless xterm mirror keeps the buffer. Reconnecting clients receive a fresh snapshot and continue right where the terminal left off.",
  },
];

const badges = [
  ...(version ? [`v${version}`] : []),
  "MIT",
  "Node >=22",
  "Win · Linux · macOS",
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>tui-bridge — any TUI, on your phone</title>
    <meta
      name="description"
      content="Bridge any TUI application to a mobile-friendly web terminal. No port forwarding, no central server, no network configuration."
    />
    <link rel="canonical" href={site} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fbfbfb" media="(prefers-color-scheme: light)" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={site} />
    <meta property="og:title" content="tui-bridge — any TUI, on your phone" />
    <meta
      property="og:description"
      content="Bridge any TUI application to a mobile-friendly web terminal. No port forwarding, no central server."
    />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="tui-bridge" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="tui-bridge — any TUI, on your phone" />
    <meta
      name="twitter:description"
      content="Bridge any TUI application to a mobile-friendly web terminal."
    />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("theme");
          if (!t)
            t = matchMedia("(prefers-color-scheme: light)").matches
              ? "light"
              : "dark";
          document.documentElement.setAttribute("data-theme", t);
        } catch {
          document.documentElement.setAttribute("data-theme", "dark");
        }
      })();
    </script>
    <Analytics />
  </head>  <body
    style="margin:0;background:var(--tb-bg);color:var(--tb-text);font-family:var(--tb-font);line-height:1.6;-webkit-font-smoothing:antialiased;"
  >
    <nav class="tb-nav">
      <div class="tb-container tb-nav-inner">
        <a class="tb-nav-brand" href="/">
          <svg viewBox="0 0 32 32" aria-hidden="true">
            <defs>
              <linearGradient id="navg" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="#34d399" />
                <stop offset="1" stop-color="#10b981" />
              </linearGradient>
            </defs>
            <rect width="32" height="32" rx="8" fill="#0a0a0a" />
            <rect x="6.5" y="6.5" width="19" height="19" rx="4.5" fill="url(#navg)" />
            <text
              x="16"
              y="16"
              text-anchor="middle"
              dominant-baseline="central"
              font-family="ui-monospace, monospace"
              font-weight="700"
              font-size="15"
              fill="#04140d">t</text>
          </svg>
          tui-bridge
        </a>
        <div class="tb-nav-links" data-nav-links>
          {
            navLinks.map((l) => (
              <a href={l.href}>
                {l.label}
              </a>
            ))
          }
          <button class="tb-theme-btn" data-theme-toggle aria-label="Toggle theme">
            <svg
              class="tb-icon-moon"
              viewBox="0 0 24 24"
              width="18"
              height="18"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M21.64 13a1 1 0 0 0-1.05-.14 8.05 8.05 0 0 1-3.37.73 8.15 8.15 0 0 1-8.14-8.1 8.59 8.59 0 0 1 .25-2A1 1 0 0 0 8 2.36 10.14 10.14 0 1 0 22 14.69 1 1 0 0 0 21.64 13Z"
              ></path>
            </svg>
            <svg
              class="tb-icon-sun"
              viewBox="0 0 24 24"
              width="18"
              height="18"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="4"></circle>
              <path
                d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
              ></path>
            </svg>
          </button>
          <a class="tb-btn tb-btn--primary" href="/installation/">Get started</a>
        </div>
        <button class="tb-nav-toggle" data-nav-toggle aria-label="Menu">
          <svg
            viewBox="0 0 24 24"
            width="20"
            height="20"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <path d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </nav>

    <main>
      <section class="tb-hero">
        <div class="tb-container">
          <div class="tb-hero-eyebrow">{siteConfig.name}</div>
          <h1 class="tb-hero-title">
            {siteConfig.heroLine1}<br /><span class="tb-accent-text">{siteConfig.heroLine2}</span>
          </h1>
          <p class="tb-hero-sub">
            {siteConfig.description}
          </p>
          <div class="tb-install" data-install-tabs>
            <div class="tb-install-tabbar" role="tablist">
              {
                installTabs.map((t, i) => (
                  <button
                    class="tb-install-tab"
                    role="tab"
                    data-tab={t.id}
                    aria-selected={i === 0 ? "true" : "false"}
                  >
                    {t.label}
                  </button>
                ))
              }
            </div>
            {
              installTabs.map((t, i) => (
                <div
                  class="tb-install-panel"
                  role="tabpanel"
                  data-panel={t.id}
                  hidden={i !== 0}
                >
                  <code class="tb-code">
                    <span class="tb-prompt">$</span>
                    <span class="tb-cmd">{t.command}</span>
                  </code>
                  <span class="tb-code-hint">{t.hint}</span>
                  <code class="tb-code tb-code--accent">
                    <span class="tb-prompt">$</span>
                    <span class="tb-cmd">tui-bridge opencode</span>
                  </code>
                </div>
              ))
            }
          </div>
          <div class="tb-hero-cta">
            <a class="tb-btn tb-btn--primary" href="/getting-started/"
              >Get started</a
            >
            <a
              class="tb-btn tb-btn--ghost"
              href={siteConfig.repo.url}>GitHub</a
            >
          </div>
          <div class="tb-badges">
            {
              badges.map((b) => (
                <span class="tb-badge">
                  <span class="tb-badge-dot" />
                  {b}
                </span>
              ))
            }
          </div>
        </div>
      </section>

      <section class="tb-section" id="how-it-works">
        <div class="tb-container">
          <div class="tb-section-head">
            <div class="tb-section-kicker">HOW IT WORKS</div>
            <h2 class="tb-section-title">Three steps. No config.</h2>
            <p class="tb-section-sub">
              The TUI runs in a local PTY; a Quick Tunnel exposes an HTTPS URL;
              you scan a QR and drive the same terminal from your phone.
            </p>
          </div>
          <div class="tb-flow">
            <pre>{`your terminal ──► tui-bridge ──► node-pty ──► <any TUI: opencode, htop, lazygit…>
                       │
                       └──► localhost HTTP/WS └──► cloudflared quick tunnel ──► mobile xterm.js`}</pre>
            <div class="tb-flow-steps">
              {
                flowSteps.map((s, i) => (
                  <div class="tb-flow-step">
                    <span class="tb-flow-num">{i + 1}</span>
                    <div>
                      <strong>{s.title}</strong>
                      <span>{s.body}</span>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
          {hasAnyScreenshot && (
            <div class="tb-demo-row">
              {hasPhoneDemo && (
                <div class="tb-screenshot-item">
                  <img
                    class="tb-screenshot"
                    src="/screenshots/phone-demo.png"
                    alt="tui-bridge running a TUI on a phone"
                    width="270"
                    loading="lazy"
                  />
                  <div class="tb-demo-caption">mobile xterm.js mirror</div>
                </div>
              )}
              {hasQrPairing && (
                <div class="tb-screenshot-item">
                  <img
                    class="tb-screenshot"
                    src="/screenshots/qr-pairing.png"
                    alt="QR code shown in the terminal for pairing"
                    width="270"
                    loading="lazy"
                  />
                  <div class="tb-demo-caption">scan to pair</div>
                </div>
              )}
            </div>
          )}
        </div>
      </section>

      <section class="tb-section" id="features">
        <div class="tb-container">
          <div class="tb-section-head">
            <div class="tb-section-kicker">FEATURES</div>
            <h2 class="tb-section-title">Built for terminal people</h2>
            <p class="tb-section-sub">
              Everything you need to reach a TUI from your phone, and nothing
              you don't.
            </p>
          </div>
          <div class="tb-feature-grid">
            {
              features.map((f) => (
                <div class="tb-feature-card">
                  <span class="tb-feature-icon" set:html={f.icon} />
                  <h3>{f.title}</h3>
                  <p>{f.body}</p>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <section class="tb-section" id="compare">
        <div class="tb-container">
          <div class="tb-section-head">
            <div class="tb-section-kicker">COMPARE</div>
            <h2 class="tb-section-title">vs. the usual suspects</h2>
            <p class="tb-section-sub">
              How tui-bridge stacks up against common ways to reach a terminal
              remotely.
            </p>
          </div>
          <div class="tb-table-wrap">
            <table class="tb-compare">
              <thead>
                <tr>
                  <th></th>
                  <th class="tb-compare-hero">tui-bridge</th>
                  <th>ssh + tmux / VPN</th>
                  <th>ngrok + web terminal</th>
                </tr>
              </thead>
              <tbody>
                {
                  compareRows.map((row) => (
                    <tr>
                      <td>{row.label}</td>
                      <td class={row.tb[0] === "yes" ? "tb-yes" : "tb-no"}>
                        {row.tb[1]}
                      </td>
                      <td class={row.ssh[0] === "yes" ? "tb-yes" : "tb-no"}>
                        {row.ssh[1]}
                      </td>
                      <td class={row.ngrok[0] === "yes" ? "tb-yes" : "tb-no"}>
                        {row.ngrok[1]}
                      </td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <section class="tb-section" id="use-cases">
        <div class="tb-container">
          <div class="tb-section-head">
            <div class="tb-section-kicker">USE CASES</div>
            <h2 class="tb-section-title">Reach your terminal from anywhere</h2>
          </div>
          <div class="tb-usecases">
            {
              usecases.map((u) => (
                <div class="tb-usecase">
                  <h3>{u.title}</h3>
                  <p>{u.body}</p>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <section class="tb-section" id="faq">
        <div class="tb-container">
          <div class="tb-section-head">
            <div class="tb-section-kicker">FAQ</div>
            <h2 class="tb-section-title">Questions</h2>
          </div>
          <div class="tb-faq">
            {
              faq.map((item) => (
                <details>
                  <summary>
                    {item.q}
                    <span class="tb-faq-mark">+</span>
                  </summary>
                  <p>{item.a}</p>
                </details>
              ))
            }
          </div>
        </div>
      </section>

      <section class="tb-cta">
        <div class="tb-container tb-cta-inner">
          <h2>Ready in 60 seconds</h2>
          <p>
            Install, point it at a TUI, scan the QR, and you're driving it from
            your phone.
          </p>
          <div class="tb-hero-cta">
            <a class="tb-btn tb-btn--primary" href="/installation/"
              >Installation guide</a
            >
            <a class="tb-btn tb-btn--ghost" href="/quick-start/">Quick start</a>
          </div>
        </div>
      </section>
    </main>

    <footer class="tb-footer">
      <div class="tb-container tb-footer-inner">
        <span>&copy; {year} tui-bridge &middot; MIT licensed</span>
        <div class="tb-footer-links">
          <a href={siteConfig.repo.url}>GitHub</a>
          <a href={siteConfig.npm.url}>npm</a>
          <a href="/getting-started/">Docs</a>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.querySelector("[data-theme-toggle]");
      toggle?.addEventListener("click", () => {
        const cur = document.documentElement.getAttribute("data-theme");
        const next = cur === "dark" ? "light" : "dark";
        document.documentElement.setAttribute("data-theme", next);
        try {
          localStorage.setItem("theme", next);
        } catch {}
      });
      const navToggle = document.querySelector("[data-nav-toggle]");
      const navLinks = document.querySelector("[data-nav-links]");
      navToggle?.addEventListener("click", () => {
        navLinks?.classList.toggle("tb-nav-open");
      });

      const tabWrap = document.querySelector("[data-install-tabs]");
      if (tabWrap) {
        const tabs = tabWrap.querySelectorAll<HTMLElement>("[data-tab]");
        const panels = tabWrap.querySelectorAll<HTMLElement>("[data-panel]");
        const selectTab = (id: string | undefined) => {
          tabs.forEach((t) =>
            t.setAttribute("aria-selected", t.dataset.tab === id ? "true" : "false"),
          );
          panels.forEach((p) => {
            p.hidden = p.dataset.panel !== id;
          });
        };
        tabs.forEach((t) =>
          t.addEventListener("click", () => selectTab(t.dataset.tab)),
        );
        const ua = navigator.userAgent || "";
        if (/Windows/i.test(ua)) selectTab("windows");
        else if (/Mac|iPhone|iPad/i.test(ua)) selectTab("macos-linux");
      }
    </script>

    <style>
      .tb-icon-sun {
        display: none;
      }
      [data-theme="light"] .tb-icon-sun {
        display: inline;
      }
      [data-theme="light"] .tb-icon-moon {
        display: none;
      }
    </style>
  </body>
</html>
